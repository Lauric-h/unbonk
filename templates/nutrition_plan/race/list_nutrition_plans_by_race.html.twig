{% extends 'base.html.twig' %}

{% block title %}Plans de nutrition - {{ race.name }}{% endblock %}

{% block body %}
    <h1>Plans de nutrition pour {{ race.name }}</h1>
    
    <p><a href="{{ path('app.race.list') }}">← Retour à mes courses</a></p>
    
    <h2>Informations de la course</h2>
    <ul>
        <li><strong>Nom :</strong> {{ race.name }}</li>
        <li><strong>Lieu :</strong> {{ race.location }}</li>
        <li><strong>Date :</strong> {{ race.startDateTime|date('d/m/Y H:i') }}</li>
        <li><strong>Distance :</strong> {{ (race.distance / 1000)|number_format(1) }} km</li>
        <li><strong>D+ :</strong> {{ race.ascent }} m</li>
        <li><strong>D- :</strong> {{ race.descent }} m</li>
        <li><strong>Checkpoints :</strong> {{ race.checkpoints|length }}</li>
    </ul>
    
    <h2>Plans de nutrition</h2>
    
    <p><a href="{{ path('app.nutrition_plan.create', {raceId: race.id}) }}">+ Créer un nouveau plan</a></p>
    
    {% if nutritionPlans|length > 0 %}
        <table border="1" cellpadding="10">
            <thead>
                <tr>
                    <th>Nom du plan</th>
                    <th>Glucides totaux</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for plan in nutritionPlans %}
                    <tr>
                        <td><strong>{{ plan.nutritionPlanName ?? '(Sans nom)' }}</strong></td>
                        <td>{{ plan.totalCarbs }} g</td>
                        <td>
                            <a href="#">Voir</a>
                            |
                            <a href="#">Éditer</a>
                            |
                            <form method="post" action="#" style="display: inline;" onsubmit="return confirm('Supprimer ce plan ?');">
                                <button type="submit">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p>Aucun plan de nutrition pour cette course.</p>
        <p><a href="{{ path('app.nutrition_plan.create', {raceId: race.id}) }}">Créer un plan de nutrition</a></p>
    {% endif %}
{% endblock %}
