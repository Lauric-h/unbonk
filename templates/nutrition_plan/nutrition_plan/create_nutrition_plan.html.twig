{% extends 'base.html.twig' %}

{% block title %}Créer un plan de nutrition - {{ race.name }}{% endblock %}

{% block body %}
    <h1>Créer un plan de nutrition</h1>
    
    <p><a href="{{ url('app.race.nutrition_plans', {raceId: race.id}) }}">← Retour aux plans de cette course</a></p>
    
    <h2>Course : {{ race.name }}</h2>
    <ul>
        <li><strong>Lieu :</strong> {{ race.location }}</li>
        <li><strong>Date :</strong> {{ race.startDateTime|date('d/m/Y H:i') }}</li>
        <li><strong>Distance :</strong> {{ (race.distance / 1000)|number_format(1) }} km</li>
        <li><strong>D+ :</strong> {{ race.ascent }} m</li>
        <li><strong>Checkpoints :</strong> {{ race.orderedCheckpoints()|length }}</li>
    </ul>
    
    <h2>Nouveau plan</h2>
    
    {{ form_start(form) }}
        {{ form_row(form.name) }}
        
        <button type="submit">Créer le plan</button>
        <a href="{{ url('app.race.nutrition_plans', {raceId: race.id}) }}">Annuler</a>
    {{ form_end(form) }}
{% endblock %}
