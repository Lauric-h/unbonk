{% extends 'base.html.twig' %}

{% block title %}{{ nutritionPlan.name ?? 'Plan de nutrition' }} - {{ nutritionPlan.race.name }}{% endblock %}

{% block body %}
    <h1>{{ nutritionPlan.name ?? 'Plan de nutrition' }}</h1>
    
    <p>
        <a href="{{ path('app.race.nutrition_plans', {raceId: nutritionPlan.race.id}) }}">← Retour aux plans de cette course</a>
        |
        <a href="{{ path('app.nutrition_plan.list') }}">Tous mes plans</a>
    </p>
    
    <h2>Informations de la course</h2>
    <ul>
        <li><strong>Événement :</strong> {{ nutritionPlan.race.eventName ?? nutritionPlan.race.name }}</li>
        <li><strong>Course :</strong> {{ nutritionPlan.race.name }}</li>
        <li><strong>Lieu :</strong> {{ nutritionPlan.race.location }}</li>
        <li><strong>Date :</strong> {{ nutritionPlan.race.startDateTime|date('d/m/Y H:i') }}</li>
        <li><strong>Distance :</strong> {{ (nutritionPlan.race.distance / 1000)|number_format(1) }} km</li>
        <li><strong>D+ :</strong> {{ nutritionPlan.race.ascent }} m</li>
        <li><strong>D- :</strong> {{ nutritionPlan.race.descent }} m</li>
    </ul>
    
    <h2>Résumé nutritionnel</h2>
    <p><strong>Total glucides :</strong> {{ nutritionPlan.totalCarbs }} g</p>
    
    <h2>Segments et nutrition</h2>
    
    {% if nutritionPlan.segments|length > 0 %}
        {% for segment in nutritionPlan.segments %}
            <h3>Segment {{ segment.position }} : {{ segment.startCheckpoint.name }} → {{ segment.endCheckpoint.name }}</h3>
            
            <table border="1" cellpadding="5" style="margin-bottom: 20px;">
                <tr>
                    <th>Distance</th>
                    <th>D+</th>
                    <th>D-</th>
                    <th>Glucides</th>
                </tr>
                <tr>
                    <td>{{ (segment.distance / 1000)|number_format(1) }} km</td>
                    <td>{{ segment.ascent }} m</td>
                    <td>{{ segment.descent }} m</td>
                    <td><strong>{{ segment.totalCarbs }} g</strong></td>
                </tr>
            </table>
            
            <h4>Checkpoints</h4>
            <ul>
                <li>
                    <strong>Départ :</strong> {{ segment.startCheckpoint.name }} 
                    ({{ (segment.startCheckpoint.distanceFromStart / 1000)|number_format(1) }} km)
                    {% if segment.startCheckpoint.cutoffInMinutes %}
                        - Cutoff : {{ segment.startCheckpoint.cutoffInMinutes|date }}
                    {% endif %}
                </li>
                <li>
                    <strong>Arrivée :</strong> {{ segment.endCheckpoint.name }} 
                    ({{ (segment.endCheckpoint.distanceFromStart / 1000)|number_format(1) }} km)
                    {% if segment.endCheckpoint.cutoffInMinutes %}
                        - Cutoff : {{ segment.endCheckpoint.cutoffInMinutes }}
                    {% endif %}
                </li>
            </ul>
            
            <h4>Nutrition prévue</h4>
            {% if segment.nutritionItems|length > 0 %}
                <table border="1" cellpadding="5">
                    <thead>
                        <tr>
                            <th>Aliment</th>
                            <th>Quantité</th>
                            <th>Glucides unitaires</th>
                            <th>Glucides totaux</th>
                            <th>Calories unitaires</th>
                            <th>Calories totales</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in segment.nutritionItems %}
                            <tr>
                                <td>{{ item.name }}</td>
                                <td>{{ item.quantity }}</td>
                                <td>{{ item.carbs }} g</td>
                                <td><strong>{{ item.carbs * item.quantity }} g</strong></td>
                                <td>{{ item.calories }} kcal</td>
                                <td><strong>{{ item.calories * item.quantity }} kcal</strong></td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <p><em>Aucun aliment prévu pour ce segment</em></p>
            {% endif %}
            
            <hr>
        {% endfor %}
    {% else %}
        <p>Aucun segment disponible.</p>
    {% endif %}
    
    <h2>Actions</h2>
    <p>
        <a href="{{ path('app.nutrition_plan.edit', {nutritionPlanId: nutritionPlan.id}) }}">Éditer ce plan</a>
        |
        <a href="{{ path('app.nutrition_plan.rename', {nutritionPlanId: nutritionPlan.id}) }}">Renommer</a>
        |
        <form method="post" action="{{ path('app.nutrition_plan.delete', {nutritionPlanId: nutritionPlan.id}) }}" style="display: inline;" onsubmit="return confirm('Supprimer ce plan ?');">
            <button type="submit">Supprimer</button>
        </form>
    </p>
{% endblock %}
