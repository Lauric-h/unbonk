<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                          https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <!-- Base entity with Single Table Inheritance -->
    <entity name="App\Domain\NutritionPlan\Entity\AbstractCheckpoint" table="checkpoint" inheritance-type="SINGLE_TABLE">
        <discriminator-column name="checkpoint_class" type="string" />
        <discriminator-map>
            <discriminator-mapping value="imported" class="App\Domain\NutritionPlan\Entity\ImportedCheckpoint" />
            <discriminator-mapping value="custom" class="App\Domain\NutritionPlan\Entity\CustomCheckpoint" />
        </discriminator-map>

        <id name="id" type="string">
            <generator strategy="NONE"/>
        </id>
        
        <field name="name" type="string"/>
        <field name="location" type="string"/>
        <field name="distanceFromStart" type="integer" column="distance_from_start"/>
        <field name="ascentFromStart" type="integer" column="ascent_from_start"/>
        <field name="descentFromStart" type="integer" column="descent_from_start"/>
        <field name="assistanceAllowed" type="boolean" column="assistance_allowed"/>
        <field name="cutoffTime" type="datetime_immutable" column="cutoff_time" nullable="true"/>
    </entity>

</doctrine-mapping>
