<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                          https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Domain\NutritionPlan\Entity\Segment" table="segment">
        <id name="id" type="string" />
        <field name="position" type="integer"/>

        <many-to-one field="runnerRace" target-entity="App\Domain\NutritionPlan\Entity\RunnerRace" inversed-by="segments">
            <join-column name="runner_race_id" referenced-column-name="id" nullable="false" on-delete="CASCADE"/>
        </many-to-one>

        <many-to-one field="fromCheckpoint" target-entity="App\Domain\NutritionPlan\Entity\Checkpoint">
            <join-column name="from_checkpoint_id" referenced-column-name="id" nullable="false" on-delete="CASCADE"/>
        </many-to-one>

        <many-to-one field="toCheckpoint" target-entity="App\Domain\NutritionPlan\Entity\Checkpoint">
            <join-column name="to_checkpoint_id" referenced-column-name="id" nullable="false" on-delete="CASCADE"/>
        </many-to-one>

        <indexes>
            <index name="idx_segment_runner_race" columns="runner_race_id"/>
            <index name="idx_segment_checkpoints" columns="from_checkpoint_id,to_checkpoint_id"/>
        </indexes>
    </entity>

</doctrine-mapping>
